# Copie para .env e preencha em produção
SECRET_KEY=sua-chave-secreta-longa-e-aleatoria
DEBUG=False
ALLOWED_HOSTS=seudominio.com,www.seudominio.com

# Banco (produção: PostgreSQL recomendado)
# DATABASE_URL=postgres://user:senha@host:5432/dbname
# Desenvolvimento (padrão): SQLite (não defina DATABASE_URL)

# Opcional
# SECURE_SSL_REDIRECT=True
